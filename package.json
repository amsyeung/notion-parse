{
  "name": "@amsyn/notion-parse",
  "version": "1.0.2",
  "type": "module",
  "description": "Convert Notion pages to Markdown with frontmatter",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/",
    "package.json",
    "README.md",
    ".release-it.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "release": "release-it"
  },
  "keywords": [
    "markdown",
    "notion",
    "frontmatter"
  ],
  "author": "Andy Yeung",
  "license": "MIT",
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "release-it": "^17.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.13",
    "jimp": "^0.22.10",
    "notion-to-md": "^3.1.1",
    "slugify": "^1.6.6",
    "yaml": "^2.3.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
